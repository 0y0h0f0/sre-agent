# Local demo defaults
DATABASE_URL=postgresql+psycopg://sre:sre@localhost:5433/sre
REDIS_URL=redis://localhost:6378/0
CELERY_BROKER_URL=redis://localhost:6378/1
CELERY_RESULT_BACKEND=redis://localhost:6378/2
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
OTEL_COLLECTOR_URL=http://localhost:4318
LLM_PROVIDER=fake
EMBEDDING_PROVIDER=fake

# Real SMTP / email notifications
# Set RUN_REAL_EMAIL_TEST=true only when you intentionally want pytest to send one real email.
RUN_REAL_EMAIL_TEST=false
SMTP_HOST=
SMTP_PORT=587
# auto: 587 STARTTLS, 465 TLS; or set starttls/tls/none explicitly.
SMTP_TLS_MODE=auto
SMTP_TIMEOUT_SECONDS=30
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Comma- or semicolon-separated recipients.
SRE_EMAIL_LIST=
WEB_BASE_URL=http://localhost:5173
NOTIFICATION_TIMEZONE=Asia/Shanghai
