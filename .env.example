# =============================================================================
# SRE Incident Response Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database & Cache ---
DATABASE_URL=postgresql+psycopg://sre:sre@localhost:5432/sre
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Observability Backends ---
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
OTEL_COLLECTOR_URL=http://localhost:4318

# --- LLM Provider (fake | vllm | openai | deepseek | anthropic) ---
LLM_PROVIDER=fake
LLM_MODEL=fake-diagnosis-model
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=30
LLM_REASONING_ENABLED=false
LLM_REASONING_EFFORT=medium

# --- Embedding & RAG ---
EMBEDDING_PROVIDER=fake
EMBEDDING_BGE_ZH_URL=http://localhost:8083
EMBEDDING_TEXT2VEC_URL=http://localhost:8084

# --- Reranker (fake | cohere | jina | bge) ---
RERANKER_PROVIDER=fake
RERANKER_COHERE_API_KEY=
RERANKER_JINA_BASE_URL=http://localhost:8081/v1
RERANKER_BGE_BASE_URL=http://localhost:8082

# --- Tool Backends (fixture | live) ---
TRACE_ENABLED=false
TRACE_BACKEND=disabled
TRACE_FIXTURE_PATH=demo/faults/traces.json
DEPLOYMENT_BACKEND=fixture
GIT_CHANGES_FIXTURE_PATH=demo/faults/git_changes.json
K8S_BACKEND=fixture
K8S_FIXTURE_PATH=demo/faults/k8s.json
DB_DIAGNOSTICS_BACKEND=fixture
DB_DIAGNOSTICS_FIXTURE_PATH=demo/faults/db_diagnostics.json

# --- Trace Backend URLs (when using live backends) ---
JAEGER_URL=http://localhost:16686
TEMPO_URL=http://localhost:3200

# --- Deployment Backend (when using live backends) ---
GITHUB_API_URL=https://api.github.com
GITHUB_REPO=
GITHUB_TOKEN=
ARGOCD_URL=http://localhost:8080
ARGOCD_TOKEN=

# --- Kubernetes (when using live backend, read-only diagnosis only) ---
K8S_NAMESPACE=default

# --- SMTP / Email Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS_MODE=auto
SMTP_TIMEOUT_SECONDS=30
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=sre-agent@example.local
SRE_EMAIL_LIST=
WEB_BASE_URL=http://localhost:5173
NOTIFICATION_TIMEZONE=UTC

# --- Authentication ---
API_KEY_AUTH_ENABLED=false
API_KEY_INITIAL_SEED=
CORS_ALLOW_ORIGINS=http://localhost:5173

# --- M9 Controlled Enhancements (all default-off) ---
M9_EXTENSIONS_ENABLED=false
RUNBOOK_LLM_GENERATION_ENABLED=false
LLM_INCIDENT_DIFF_ENABLED=false
RUNBOOK_WEB_SEARCH_ENABLED=false
TEMPO_DISCOVERY_ENABLED=false
GRAFANA_ALERT_INGEST_ENABLED=false
SEMANTIC_RUNBOOK_SEARCH_ENABLED=false
EXTERNAL_EMBEDDING_PROVIDER_ENABLED=false
LLM_EXTERNAL_PROVIDER_ALLOWED=false
# Pre-M9 trace state for total M9 rollback (set before enabling M9)
PRE_M9_TRACE_BACKEND=
PRE_M9_TRACE_ENABLED=

# --- Celery (set to True for running tasks synchronously in tests) ---
CELERY_TASK_ALWAYS_EAGER=false
