# =============================================================================
# SRE Agent Secret 模板 — cp 为 .env.secret 并填入真实值
# =============================================================================
# 生成: cp deploy/k8s/base/.env.secret.example deploy/k8s/base/.env.secret
# 编辑: vim deploy/k8s/base/.env.secret
# 部署: kubectl apply -k deploy/k8s/base/
# =============================================================================
# ⚠️  .env.secret 已被 .gitignore，不会被签入 git
# ⚠️  下面的密码必须和 postgres.yaml 中 postgres-credentials.password 一致
# =============================================================================

# --- 数据库 & 缓存 (密码要和 postgres.yaml 的 Secret 一致) ---
DATABASE_URL=postgresql+psycopg://sre:changeme@postgres.sre-agent.svc.cluster.local:5432/sre
REDIS_URL=redis://redis.sre-agent.svc.cluster.local:6379/0
CELERY_BROKER_URL=redis://redis.sre-agent.svc.cluster.local:6379/1
CELERY_RESULT_BACKEND=redis://redis.sre-agent.svc.cluster.local:6379/2

# --- DeepSeek API Key (⚠️ 必须填真实 key) ---
LLM_API_KEY=<replace-with-deepseek-api-key>

# --- SMTP 邮件通知 ---
# SMTP_HOST 为空时系统会把邮件记录为 skipped，不会真实发送。
# 如需在 K8s 中收到 new_incident / approval_request / diagnosis_complete 邮件，
# 取消注释并填写下面这些值；Secret env 会覆盖 ConfigMap 中的安全默认值。
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_TLS_MODE=starttls
# SMTP_FROM=sre-agent@example.com
# SRE_EMAIL_LIST=sre@example.com,oncall@example.com
# WEB_BASE_URL=https://sre-agent.example.com
SMTP_USER=
SMTP_PASSWORD=

# --- Alertmanager (默认无认证，留空) ---
ALERTMANAGER_READ_TOKEN=

# --- Grafana Webhook HMAC Secret (GRAFANA_ALERT_INGEST_ENABLED=true 时必填) ---
GRAFANA_WEBHOOK_SECRET_REF=

# --- API Key 初始种子 (生成: python3 -c "import secrets; print(secrets.token_urlsafe(32))") ---
API_KEY_INITIAL_SEED=
